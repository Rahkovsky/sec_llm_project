# Copy to .env and fill in. Secrets are read from the environment, never code.

# SEC EDGAR identity — used to build a fair-access-compliant User-Agent.
SEC_USER_NAME="Your Name"
SEC_USER_EMAIL="your.email@example.com"

# Model backends (only what your chosen config profile needs):
# config/default.yaml  -> OpenAI generation + embeddings
OPENAI_API_KEY=""
# Optional: route OpenAI-compatible calls (e.g. Azure OpenAI Government gateway)
# OPENAI_BASE_URL=""

# config/anthropic.json -> Anthropic generation
ANTHROPIC_API_KEY=""

# config/local.yaml -> Ollama (no key); override host if not localhost:11434
# OLLAMA_BASE_URL="http://localhost:11434"

# Optional: override any config value (dotted, double-underscore nested)
# SECI_LLM__PROVIDER=ollama
# SECI_RETRIEVAL__RERANK=true
