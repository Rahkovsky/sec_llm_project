{
  "llm": {
    "provider": "anthropic",
    "model": "claude-opus-4-8",
    "base_url": "",
    "api_key_env": "ANTHROPIC_API_KEY",
    "temperature": 0.0,
    "max_tokens": 1024,
    "seed": 7,
    "timeout": 120.0
  },
  "embedding": {
    "provider": "openai",
    "model": "text-embedding-3-large",
    "dim": 3072,
    "normalize": true,
    "api_key_env": "OPENAI_API_KEY",
    "base_url": "",
    "version": "v1"
  },
  "chunking": {
    "max_chars": 1800,
    "overlap_chars": 200,
    "min_chars": 200,
    "sec_aware": true
  },
  "retrieval": {
    "top_k": 8,
    "candidate_k": 40,
    "use_bm25": true,
    "use_dense": true,
    "fusion": "rrf",
    "rrf_k": 60,
    "bm25_weight": 0.5,
    "dense_weight": 0.5,
    "rerank": true,
    "reranker_model": "cross-encoder/ms-marco-MiniLM-L-6-v2"
  },
  "generation": {
    "min_evidence_score": 0.05,
    "min_citations": 1,
    "abstain_below_confidence": 0.15,
    "max_context_chunks": 6,
    "quote_chars": 240
  },
  "index": {
    "store": "chroma",
    "path": "data/sec_index",
    "collection": "sec_filings"
  },
  "audit": {
    "enabled": true,
    "path": "logs/audit.jsonl"
  },
  "local_fallback": {
    "enabled": false,
    "llm": {
      "provider": "ollama",
      "model": "gemma3:12b",
      "base_url": "",
      "api_key_env": "",
      "temperature": 0.0,
      "max_tokens": 768,
      "seed": 7,
      "timeout": 120.0
    },
    "embedding": {
      "provider": "nomic",
      "model": "nomic-ai/nomic-embed-text-v1.5",
      "dim": 768,
      "normalize": true,
      "api_key_env": "",
      "base_url": "",
      "version": "v1"
    }
  }
}
